<section id="portfolio" class="section-padding">
  <div class="container-custom">
    <div class="text-center mb-12 animate-on-scroll">
      <h2 class="mb-4">Portfolio</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        A showcase of costume designs across film, theater, and fashion projects
      </p>
    </div>
    
    <!-- Portfolio Categories -->
    <div class="flex flex-wrap justify-center gap-4 mb-12 animate-on-scroll">
      {categories.map(category => (
        <button 
          class="portfolio-filter px-6 py-2 rounded-full border-2 border-primary-200 transition-all duration-300 capitalize hover:bg-primary-50"
          data-category={category}
        >
          {category}
        </button>
      ))}
    </div>
    
    <!-- Portfolio Grid -->
    <div class="portfolio-grid animate-on-scroll">
      {portfolioItems.map(item => (
        <div class="portfolio-item" data-category={item.category}>
          <img 
            src={item.images[0]} 
            alt={item.title} 
            class="w-full h-80 object-cover"
          />
          <div class="portfolio-overlay">
            <div class="text-center p-4">
              <h3 class="text-white text-xl mb-2 font-serif">{item.title}</h3>
              <p class="text-gray-200 text-sm">{item.description}</p>
              <span class="inline-block mt-3 bg-accent-500 text-white text-xs px-3 py-1 rounded-full uppercase tracking-wider">
                {item.category}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Portfolio filtering
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.portfolio-filter');
    const portfolioItems = document.querySelectorAll('.portfolio-item');
    
    // Set 'all' category as active by default
    const allButton = document.querySelector('[data-category="all"]');
    allButton.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
    
    // Filter function
    const filterPortfolio = (category) => {
      portfolioItems.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        
        if (category === 'all' || category === itemCategory) {
          item.style.display = 'block';
          // Add animation for appearing items
          item.classList.add('animate-fade-in');
          setTimeout(() => {
            item.classList.remove('animate-fade-in');
          }, 500);
        } else {
          item.style.display = 'none';
        }
      });
    };
    
    // Click event for filter buttons
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Reset all buttons
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
        });
        
        // Set active button
        button.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
        
        // Filter portfolio
        const category = button.getAttribute('data-category');
        filterPortfolio(category);
      });
    });
  });
</script>